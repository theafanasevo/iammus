{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "publishDate": {
      "type": "string",
      "format": "date-time"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "img": {
      "type": "string"
    },
    "img_alt": {
      "type": "string"
    },
    "embedded": {
      "type": "string",
      "enum": [
        "x",
        "bluesky",
        "substack",
        "youtube",
        "medium",
        "instagram"
      ]
    },
    "embedUrl": {
      "type": "string",
      "format": "uri"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "publishDate",
    "tags"
  ]
}