---
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About | Mustafa Kursun" description="About Mustafa">
	<div class="stack gap-20">
		<main class="wrapper about">
			<Hero
				title="About"
				tagline="Thanks for stopping by. Read below to learn more about myself and my background."
			>
				<img
					width="1553"
					height="873"
					src="/assets/cindewulung-codingshirt-candid.jpg"
					alt="Mustafa is among tropical plants in Indonesia"
				/>
			</Hero>
			<section>
				<h2 class="section-title">Background</h2>
				<div class="content">
					<p>
						Hi, I’m Mus. 👋
					</p>
					<p>
						I write clean code, connect complex systems, and translate 'tech-speak' into plain human language. 
					</p>
					<p>
						With a background in Technical Project Management and 4 years of backend adventures (Node.js, Python, AWS) in the Fintech and Insurtech worlds, 
						I act as the bridge between big business ideas and solid technical reality.
					</p>
					<p>
						Recently, I completed my toughest project yet: successfully integrating into Germany and mastering Deutsch (B2+ unlocked! 🔓). 
						Now, I’m ready for my next big challenge!
					</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">Education</h2>
				<div class="content">
					<p>
						<strong>B.A. Translation and Interpretation (English)</strong><br />
						Hacettepe University, Ankara | 2009 – 2013
					</p>
					<p>
						<em>Plot twist:</em> I actually started my career translating human languages. Today, I translate complex business requirements into Node.js and Python. At the end of the day, it's all just syntax, context, and logic!
					</p>
					<br />
					<p>
						<strong>M.S. Asian Studies (Coursework)</strong><br />
						Middle East Technical University (ODTÜ), Ankara | 2015 – 2016
					</p>
					<p>
						Satisfying my deep curiosity about different cultures, histories, and systems. (This is also the era that eventually connected me to Indonesia, giving me the nickname <strong>'Mus'</strong>!).
					</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">Skills</h2>
				<div class="content">
					<p>
						<strong>Backend & Cloud:</strong> Node.js, Python (Django), PHP, AWS (Lambda, SNS/SQS, S3, API Gateway), REST, Microservices
					</p>
					<p>
						<strong>Frontend:</strong> Vue.js, Nuxt.js, HTML5, CSS3/Sass
					</p>
					<p>
						<strong>Databases & DevOps:</strong> PostgreSQL, DynamoDB, MySQL, Git, Jenkins
					</p>
					<p>
						<strong>Tools & AI:</strong> Jira, Postman, JMeter, n8n, Claude, GitHub Copilot
					</p>
					<p>
						<strong>Soft Skills:</strong> Teamwork, Intercultural Communication, Requirements Engineering, Precise Technical Documentation
					</p>
				</div>
			</section>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.about {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
	}

	img {
		margin-top: 1.5rem;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	section {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		color: var(--gray-200);
	}

	.section-title {
		grid-column-start: 1;
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	.content {
		grid-column: 2 / 4;
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.about {
			display: grid;
			grid-template-columns: 1fr 60% 1fr;
		}

		.about > :global(:first-child) {
			grid-column-start: 2;
		}

		section {
			display: contents;
			font-size: var(--text-lg);
		}
	}
</style>